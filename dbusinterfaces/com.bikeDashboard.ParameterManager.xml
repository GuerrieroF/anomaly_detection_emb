<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
                      "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <!-- Interfaccia ParameterManager -->
  <interface name="com.bikeDashboard.ParameterManager">
    <!-- Ritorna la lista degli ID parametri -->
    <method name="ListParameters">
      <arg type="as" direction="out"/>
    </method>

    <!-- Restituisce il path dell’oggetto Parameter -->
    <method name="GetParameter">
      <arg type="s" direction="in"/>   <!-- id -->
      <arg type="o" direction="out"/>  <!-- object path -->
    </method>
  </interface>

  <!-- Interfaccia Parameter (per ogni parametro singolo) -->
  <interface name="com.bikeDashboard.Parameter">
    <!-- Ottieni valore -->
    <method name="GetValue">
      <arg type="s" direction="out"/>
    </method>

    <!-- Imposta valore -->
    <method name="SetValue">
      <arg type="s" direction="in"/>
    </method>

    <!-- Reset valore a default -->
    <method name="Reset">
      <arg type="b" direction="out"/> <!-- successo -->
    </method>

    <!-- Proprietà leggibili -->
    <property name="Id" type="s" access="read"/>
    <property name="Unit" type="s" access="read"/>
    <property name="Type" type="s" access="read"/>
    <property name="Min" type="s" access="read"/>
    <property name="Max" type="s" access="read"/>

    <!-- Segnale quando cambia valore -->
    <signal name="ValueChanged">
      <arg type="s"/> <!-- nuovo valore -->
    </signal>
  </interface>
</node>

